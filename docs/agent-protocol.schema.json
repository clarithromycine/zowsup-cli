{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zowsup.local/schemas/agent-protocol.schema.json",
  "title": "Zowsup Agent Protocol",
  "description": "JSON Schema for Backend <-> Agent websocket messages (Draft v0.3)",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/AgentAuthMessage" },
    { "$ref": "#/$defs/AgentAuthOkMessage" },
    { "$ref": "#/$defs/HeartbeatMessage" },
    { "$ref": "#/$defs/CommandStartBotMessage" },
    { "$ref": "#/$defs/CommandStopBotMessage" },
    { "$ref": "#/$defs/CommandGetBotStatusMessage" },
    { "$ref": "#/$defs/CommandListBotsMessage" },
    { "$ref": "#/$defs/CommandFetchQrMessage" },
    { "$ref": "#/$defs/CommandAckMessage" },
    { "$ref": "#/$defs/CommandResultMessage" },
    { "$ref": "#/$defs/EventAgentOnlineMessage" },
    { "$ref": "#/$defs/EventAgentHeartbeatMessage" },
    { "$ref": "#/$defs/EventBotSnapshotMessage" },
    { "$ref": "#/$defs/EventBotStatusChangedMessage" },
    { "$ref": "#/$defs/EventBotLogMessage" },
    { "$ref": "#/$defs/EventQrUpdatedMessage" },
    { "$ref": "#/$defs/EventMessageIngestedMessage" },
    { "$ref": "#/$defs/ErrorMessage" }
  ],
  "$defs": {
    "Uuid": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-4[0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$"
    },
    "AgentId": {
      "type": "string",
      "minLength": 3,
      "maxLength": 64,
      "pattern": "^[A-Za-z0-9_-]+$"
    },
    "Phone": {
      "type": "string",
      "pattern": "^[0-9]{7,15}$"
    },
    "UnixSeconds": {
      "type": "integer",
      "minimum": 0
    },
    "Semver": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][A-Za-z0-9.-]+)?$"
    },
    "ErrorObject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "retryable"],
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "auth_failed",
            "agent_disabled",
            "session_expired",
            "payload_invalid",
            "command_not_supported",
            "bot_already_running",
            "bot_not_found",
            "bot_start_failed",
            "command_timeout",
            "internal_error",
            "protocol_version_unsupported"
          ]
        },
        "message": { "type": "string", "minLength": 1 },
        "retryable": { "type": "boolean" },
        "detail": { "type": "object" }
      }
    },
    "SecurityObject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kid", "alg", "nonce", "signed_at", "signature"],
      "properties": {
        "kid": { "type": "string", "minLength": 1, "maxLength": 128 },
        "alg": { "type": "string", "enum": ["hmac-sha256"] },
        "nonce": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{16,128}$"
        },
        "signed_at": { "$ref": "#/$defs/UnixSeconds" },
        "signature": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{20,512}$"
        }
      }
    },
    "EnvelopeBase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "msg_id",
        "protocol_version",
        "type",
        "name",
        "agent_id",
        "timestamp",
        "payload"
      ],
      "properties": {
        "msg_id": { "$ref": "#/$defs/Uuid" },
        "protocol_version": {
          "type": "string",
          "enum": ["1.0"]
        },
        "type": {
          "type": "string",
          "enum": [
            "auth",
            "auth_ok",
            "command",
            "command_ack",
            "command_result",
            "event",
            "heartbeat",
            "error"
          ]
        },
        "name": { "type": "string", "minLength": 1 },
        "agent_id": { "$ref": "#/$defs/AgentId" },
        "timestamp": { "$ref": "#/$defs/UnixSeconds" },
        "session_token": { "type": "string", "minLength": 1 },
        "payload": { "type": "object" },
        "trace_id": { "$ref": "#/$defs/Uuid" },
        "security": { "$ref": "#/$defs/SecurityObject" }
      }
    },

    "AgentAuthMessage": {
      "allOf": [
        { "$ref": "#/$defs/EnvelopeBase" },
        {
          "properties": {
            "type": { "const": "auth" },
            "name": { "const": "agent_auth" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["agent_key", "agent_version"],
              "properties": {
                "agent_key": { "type": "string", "minLength": 32 },
                "agent_version": { "$ref": "#/$defs/Semver" },
                "hostname": { "type": "string", "minLength": 1, "maxLength": 255 }
              }
            }
          }
        }
      ]
    },

    "AgentAuthOkMessage": {
      "allOf": [
        { "$ref": "#/$defs/EnvelopeBase" },
        {
          "properties": {
            "type": { "const": "auth_ok" },
            "name": { "const": "agent_auth_ok" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["session_token", "expires_at"],
              "properties": {
                "session_token": { "type": "string", "minLength": 1 },
                "expires_at": { "$ref": "#/$defs/UnixSeconds" }
              }
            }
          }
        }
      ]
    },

    "HeartbeatMessage": {
      "allOf": [
        { "$ref": "#/$defs/EnvelopeBase" },
        {
          "properties": {
            "type": { "const": "heartbeat" },
            "name": { "const": "agent_heartbeat" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["bot_count", "running_count"],
              "properties": {
                "bot_count": { "type": "integer", "minimum": 0 },
                "running_count": { "type": "integer", "minimum": 0 },
                "queue_backlog": { "type": "integer", "minimum": 0 },
                "load": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "cpu_pct": { "type": "number", "minimum": 0, "maximum": 100 },
                    "mem_pct": { "type": "number", "minimum": 0, "maximum": 100 }
                  }
                }
              }
            }
          }
        }
      ]
    },

    "CommandStartBotMessage": {
      "allOf": [
        { "$ref": "#/$defs/EnvelopeBase" },
        {
          "required": ["session_token"],
          "properties": {
            "type": { "const": "command" },
            "name": { "const": "start_bot" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["phone"],
              "properties": {
                "phone": { "$ref": "#/$defs/Phone" },
                "boot_mode": { "type": "string", "enum": ["normal", "safe"] },
                "env": { "type": "object" }
              }
            }
          }
        }
      ]
    },

    "CommandStopBotMessage": {
      "allOf": [
        { "$ref": "#/$defs/EnvelopeBase" },
        {
          "required": ["session_token"],
          "properties": {
            "type": { "const": "command" },
            "name": { "const": "stop_bot" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["phone"],
              "properties": {
                "phone": { "$ref": "#/$defs/Phone" },
                "force": { "type": "boolean" }
              }
            }
          }
        }
      ]
    },

    "CommandGetBotStatusMessage": {
      "allOf": [
        { "$ref": "#/$defs/EnvelopeBase" },
        {
          "required": ["session_token"],
          "properties": {
            "type": { "const": "command" },
            "name": { "const": "get_bot_status" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["phone"],
              "properties": {
                "phone": { "$ref": "#/$defs/Phone" }
              }
            }
          }
        }
      ]
    },

    "CommandListBotsMessage": {
      "allOf": [
        { "$ref": "#/$defs/EnvelopeBase" },
        {
          "required": ["session_token"],
          "properties": {
            "type": { "const": "command" },
            "name": { "const": "list_bots" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "include_stopped": { "type": "boolean" }
              }
            }
          }
        }
      ]
    },

    "CommandFetchQrMessage": {
      "allOf": [
        { "$ref": "#/$defs/EnvelopeBase" },
        {
          "required": ["session_token"],
          "properties": {
            "type": { "const": "command" },
            "name": { "const": "fetch_qr" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["phone"],
              "properties": {
                "phone": { "$ref": "#/$defs/Phone" },
                "mode": { "type": "string", "enum": ["scan", "link"] }
              }
            }
          }
        }
      ]
    },

    "CommandAckMessage": {
      "allOf": [
        { "$ref": "#/$defs/EnvelopeBase" },
        {
          "properties": {
            "type": { "const": "command_ack" },
            "name": {
              "type": "string",
              "enum": ["start_bot", "stop_bot", "get_bot_status", "list_bots", "fetch_qr"]
            },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["ack_msg_id", "accepted"],
              "properties": {
                "ack_msg_id": { "$ref": "#/$defs/Uuid" },
                "accepted": { "type": "boolean" },
                "reason": { "type": "string" }
              }
            }
          }
        }
      ]
    },

    "CommandResultMessage": {
      "allOf": [
        { "$ref": "#/$defs/EnvelopeBase" },
        {
          "properties": {
            "type": { "const": "command_result" },
            "name": {
              "type": "string",
              "enum": ["start_bot", "stop_bot", "get_bot_status", "list_bots", "fetch_qr"]
            },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["command_msg_id", "status"],
              "properties": {
                "command_msg_id": { "$ref": "#/$defs/Uuid" },
                "status": { "type": "string", "enum": ["succeeded", "failed", "timeout"] },
                "result": { "type": "object" },
                "error": { "$ref": "#/$defs/ErrorObject" }
              }
            }
          }
        }
      ]
    },

    "EventAgentOnlineMessage": {
      "allOf": [
        { "$ref": "#/$defs/EnvelopeBase" },
        {
          "required": ["session_token"],
          "properties": {
            "type": { "const": "event" },
            "name": { "const": "agent_online" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["hostname", "agent_version", "capabilities"],
              "properties": {
                "hostname": { "type": "string", "minLength": 1, "maxLength": 255 },
                "ip": { "type": "string" },
                "agent_version": { "$ref": "#/$defs/Semver" },
                "capabilities": {
                  "type": "array",
                  "items": { "type": "string", "minLength": 1 },
                  "minItems": 1,
                  "uniqueItems": true
                },
                "tags": {
                  "type": "array",
                  "items": { "type": "string" },
                  "uniqueItems": true
                }
              }
            }
          }
        }
      ]
    },

    "EventAgentHeartbeatMessage": {
      "allOf": [
        { "$ref": "#/$defs/EnvelopeBase" },
        {
          "required": ["session_token"],
          "properties": {
            "type": { "const": "event" },
            "name": { "const": "agent_heartbeat" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["bot_count", "running_count"],
              "properties": {
                "bot_count": { "type": "integer", "minimum": 0 },
                "running_count": { "type": "integer", "minimum": 0 },
                "queue_backlog": { "type": "integer", "minimum": 0 },
                "load": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "cpu_pct": { "type": "number", "minimum": 0, "maximum": 100 },
                    "mem_pct": { "type": "number", "minimum": 0, "maximum": 100 }
                  }
                }
              }
            }
          }
        }
      ]
    },

    "BotStatusItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phone", "running"],
      "properties": {
        "phone": { "$ref": "#/$defs/Phone" },
        "running": { "type": "boolean" },
        "pid": { "type": "integer", "minimum": 1 },
        "bot_jid": { "type": "string" },
        "last_seen": { "$ref": "#/$defs/UnixSeconds" },
        "health": { "type": "string", "enum": ["ok", "warn", "error"] }
      }
    },

    "EventBotSnapshotMessage": {
      "allOf": [
        { "$ref": "#/$defs/EnvelopeBase" },
        {
          "required": ["session_token"],
          "properties": {
            "type": { "const": "event" },
            "name": { "const": "bot_snapshot" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["snapshot_id", "bots"],
              "properties": {
                "snapshot_id": { "type": "string", "minLength": 1 },
                "bots": {
                  "type": "array",
                  "items": { "$ref": "#/$defs/BotStatusItem" }
                }
              }
            }
          }
        }
      ]
    },

    "EventBotStatusChangedMessage": {
      "allOf": [
        { "$ref": "#/$defs/EnvelopeBase" },
        {
          "required": ["session_token"],
          "properties": {
            "type": { "const": "event" },
            "name": { "const": "bot_status_changed" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["phone", "running", "changed_at"],
              "properties": {
                "phone": { "$ref": "#/$defs/Phone" },
                "running": { "type": "boolean" },
                "pid": { "type": "integer", "minimum": 1 },
                "bot_jid": { "type": "string" },
                "reason": {
                  "type": "string",
                  "enum": ["manual_stop", "crash", "restart", "login_success"]
                },
                "changed_at": { "$ref": "#/$defs/UnixSeconds" }
              }
            }
          }
        }
      ]
    },

    "EventBotLogMessage": {
      "allOf": [
        { "$ref": "#/$defs/EnvelopeBase" },
        {
          "required": ["session_token"],
          "properties": {
            "type": { "const": "event" },
            "name": { "const": "bot_log" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["phone", "level", "message", "ts", "seq"],
              "properties": {
                "phone": { "$ref": "#/$defs/Phone" },
                "level": {
                  "type": "string",
                  "enum": ["DEBUG", "INFO", "WARNING", "ERROR", "CRITICAL"]
                },
                "logger": { "type": "string" },
                "message": { "type": "string", "minLength": 1, "maxLength": 4000 },
                "ts": {
                  "type": "string",
                  "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2}:[0-9]{2}$"
                },
                "seq": { "type": "integer", "minimum": 0 },
                "dropped_count": { "type": "integer", "minimum": 0 }
              }
            }
          }
        }
      ]
    },

    "EventQrUpdatedMessage": {
      "allOf": [
        { "$ref": "#/$defs/EnvelopeBase" },
        {
          "required": ["session_token"],
          "properties": {
            "type": { "const": "event" },
            "name": { "const": "qr_updated" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["session_id", "format", "content"],
              "properties": {
                "session_id": { "type": "string", "minLength": 1 },
                "format": { "type": "string", "enum": ["ascii", "png_base64"] },
                "content": { "type": "string", "minLength": 1 },
                "expires_at": { "$ref": "#/$defs/UnixSeconds" }
              }
            }
          }
        }
      ]
    },

    "EventMessageIngestedMessage": {
      "allOf": [
        { "$ref": "#/$defs/EnvelopeBase" },
        {
          "required": ["session_token"],
          "properties": {
            "type": { "const": "event" },
            "name": { "const": "message_ingested" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["phone", "message_id", "user_jid", "direction", "timestamp"],
              "properties": {
                "phone": { "$ref": "#/$defs/Phone" },
                "message_id": { "type": "string", "minLength": 1 },
                "user_jid": { "type": "string", "minLength": 1 },
                "direction": { "type": "string", "enum": ["in", "out"] },
                "timestamp": { "$ref": "#/$defs/UnixSeconds" }
              }
            }
          }
        }
      ]
    },

    "ErrorMessage": {
      "allOf": [
        { "$ref": "#/$defs/EnvelopeBase" },
        {
          "properties": {
            "type": { "const": "error" },
            "name": { "const": "error" },
            "payload": { "$ref": "#/$defs/ErrorObject" }
          }
        }
      ]
    }
  }
}
